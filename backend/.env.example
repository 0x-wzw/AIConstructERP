# Copy to .env and adjust as needed.

# SQLite (default, zero-setup local dev):
DATABASE_URL=sqlite:///./constructerp.db

# PostgreSQL (production / Supabase) — install psycopg first:
#   DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/constructerp

# CORS: "*" for any origin, or a comma-separated allowlist:
#   CORS_ORIGINS=http://localhost:8000,https://your-frontend.example
CORS_ORIGINS=*
