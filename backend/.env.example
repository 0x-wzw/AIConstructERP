# ── Database ──────────────────────────────────────────
# SQLite for dev, PostgreSQL for production:
# DATABASE_URL=postgresql+psycopg://constructerp:${POSTGRES_PASSWORD}@localhost:5432/constructerp
DATABASE_URL=sqlite:///./constructerp.db
# Required by docker-compose (Postgres + no weak fallback). Generate with:
#   python -c 'import secrets;print(secrets.token_urlsafe(24))'
POSTGRES_PASSWORD=

# ── Auth ──────────────────────────────────────────────
# REQUIRED. A static/shared value lets anyone forge admin JWTs.
# Generate with: python -c 'import secrets;print(secrets.token_hex(32))'
SECRET_KEY=
# CORS_ORIGINS=http://localhost:3000,https://app.constructerp.dev
CORS_ORIGINS=*

# ── File Storage ──────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
# S3 / MinIO / R2 / Spaces (any S3-compatible object store):
# For the bundled MinIO (docker compose --profile s3), set strong values and
# reuse them for MINIO_ROOT_USER / MINIO_ROOT_PASSWORD below.
# S3_BUCKET=constructerp
# S3_KEY=
# S3_SECRET=
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# MinIO root creds (must match S3_KEY / S3_SECRET). Generate strong values:
#   python -c 'import secrets;print(secrets.token_urlsafe(18))'
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=
# MinIO/self-hosted need path-style addressing:
# S3_FORCE_PATH_STYLE=true
# Lifetime of pre-signed direct-to-cloud upload/download URLs (seconds):
# S3_PRESIGNED_EXPIRY_SECONDS=3600

# ── Chunked / resumable upload (large tender docs) ────
# CHUNK_TEMP_DIR=./uploads/_chunks
# UPLOAD_CHUNK_SIZE_BYTES=8388608      # 8 MB
# MAX_CHUNKS_PER_UPLOAD=1024
# CHUNK_TTL_SECONDS=86400

# ── AI Agent ──────────────────────────────────────────
# AI_PROVIDER=openai | ollama | disabled
AI_PROVIDER=disabled
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── App ───────────────────────────────────────────────
# Demo users ship with PUBLIC passwords and are only ever seeded on a SQLite
# dev DB. Keep this false; flip to true only for throwaway local dev.
SEED_DEMO_USERS=false